
public class Sayıbulma {
    public static void main(String[] args){
        int[] sayılar=new int[] {1,2,4,6,7,8,3};
        int target=14;
        boolean isimsiz=false;
        for (int ara:sayılar){
            if (target==ara){
                isimsiz=true;
                break;

            }
        }if (isimsiz){
            System.out.println("Evet var");
        }
        else {
            System.out.println("Hayır yok");
        }
    }
}
